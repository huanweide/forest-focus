<script id="mw-moderation-patch-edit-links">;(window.RLQ ||= []).push([
  'mediawiki.base',
  () => {
    mw.hook('wikipage.content').add(() => {
      const editLinks = document.querySelectorAll('a#ca-edit, #ca-edit a')
      if (!editLinks.length) {
        return
      }
      editLinks.forEach((i) => {
        const url = new URL(i.href)
        url.searchParams.delete('oldid')
        i.href = url.href
      })
    })
  },
])</script>
